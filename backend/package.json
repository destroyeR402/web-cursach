{
  "name": "tv-schedule",
  "version": "1.0.0",
  "description": "Клиент-серверное веб-приложение «Расписание телепередач» — курсовая работа по дисциплине «Технологии веб-программирования»",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
