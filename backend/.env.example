# ===== Сервер =====
NODE_ENV=development
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000

# ===== PostgreSQL =====
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=tv_schedule
PG_USER=postgres
PG_PASSWORD=postgres
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000

# ===== Сессии =====
SESSION_SECRET=change_me_to_long_random_string_32_chars_min
SESSION_NAME=tv_sched.sid
SESSION_MAX_AGE_MS=86400000

# ===== JWT (для REST API) =====
JWT_SECRET=change_me_to_another_long_random_string
JWT_EXPIRES_IN=24h
JWT_COOKIE_NAME=tv_sched_token

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=10

# ===== Multer / загрузка файлов =====
UPLOAD_DIR=public/images
UPLOAD_MAX_SIZE_BYTES=5242880
UPLOAD_ALLOWED_MIME=image/png,image/jpeg,image/webp

# ===== Логирование =====
LOG_LEVEL=info
LOG_FORMAT=dev

# ===== Уведомления (email) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tv-schedule.local
