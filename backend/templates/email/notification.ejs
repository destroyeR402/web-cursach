<!doctype html>
<html>

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<title>
		<%= subject %>
	</title>
	<style>
		body {
			font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;
			color: #222;
		}

		.wrap {
			max-width: 680px;
			margin: 24px auto;
			padding: 20px;
			border: 1px solid #eee;
			border-radius: 6px;
		}

		.header {
			border-bottom: 1px solid #eee;
			padding-bottom: 12px;
			margin-bottom: 18px
		}

		.footer {
			font-size: 12px;
			color: #888;
			margin-top: 22px;
			border-top: 1px solid #f2f2f2;
			padding-top: 12px
		}

		.brand {
			color: #0a58ca;
			font-weight: 600
		}
	</style>
</head>

<body>
	<div class="wrap">
		<div class="header">
			<div class="brand">TV Schedule</div>
			<div style="font-size:13px;color:#666">Уведомление — <%= (new Date()).toLocaleString('ru-RU') %>
			</div>
		</div>
		<h2 style="margin-top:0">
			<%= subject %>
		</h2>
		<div>
			<% if (isHtml) { %>
				<%- body %>
					<% } else { %>
						<pre
							style="white-space:pre-wrap;font-family:inherit;border-left:3px solid #f0f0f0;padding-left:10px"><%= body %></pre>
						<% } %>
		</div>

		<div class="footer">
			Если вы не хотите получать эти уведомления — зайдите в настройки и отключите уведомления для канала.
		</div>
	</div>
</body>

</html>