<section class="admin-logs">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:18px">
    <div>
      <div class="eyebrow" style="margin-bottom:8px">Администрирование · Аудит</div>
      <h1 style="font-size:40px;font-weight:400;letter-spacing:-0.03em;margin:0">
        Журнал <span style="color:var(--primary);font-weight:300">событий</span>
      </h1>
    </div>
    <button class="btn" id="btnExport">⤓ CSV</button>
  </div>

  <div class="card" style="padding:14px 16px;margin-bottom:14px">
    <div class="logs-filters">
      <div class="logs-filter">
        <span class="label">Поиск</span>
        <input id="fSearch" class="input" type="search" placeholder="Действие, пользователь, IP…" value="<%= params.search || '' %>">
      </div>
      <div class="logs-filter">
        <span class="label">Действие</span>
        <select id="fAction" class="select">
          <option value="">— все —</option>
          <% actions.forEach(function(a) { %>
            <option value="<%= a %>" <%= params.action === a ? 'selected' : '' %>><%= a %></option>
          <% }); %>
        </select>
      </div>
      <div class="logs-filter">
        <span class="label">Сущность</span>
        <select id="fEntity" class="select">
          <option value="">— все —</option>
          <% entities.forEach(function(e) { %>
            <option value="<%= e %>" <%= params.entity === e ? 'selected' : '' %>><%= e %></option>
          <% }); %>
        </select>
      </div>
      <div class="logs-filter">
        <span class="label">С даты</span>
        <input id="fDateFrom" class="input" type="datetime-local" value="<%= params.dateFrom || '' %>">
      </div>
      <div class="logs-filter">
        <span class="label">По дату</span>
        <input id="fDateTo" class="input" type="datetime-local" value="<%= params.dateTo || '' %>">
      </div>
      <div class="logs-filter logs-filter-actions">
        <button class="btn btn-sm" id="fReset" type="button">Сбросить</button>
      </div>
    </div>
  </div>

  <div class="card" style="overflow:hidden;margin-bottom:4px">
    <table class="data-table" id="logsTable">
      <thead>
        <tr>
          <th class="js-sort" data-sort="created_at" style="width:170px;cursor:pointer">Дата · Время <span class="sort-ind"></span></th>
          <th class="js-sort" data-sort="username" style="width:160px;cursor:pointer">Пользователь <span class="sort-ind"></span></th>
          <th class="js-sort" data-sort="action" style="cursor:pointer">Действие <span class="sort-ind"></span></th>
          <th class="js-sort" data-sort="entity" style="width:110px;cursor:pointer">Сущность <span class="sort-ind"></span></th>
          <th style="width:130px">ID</th>
          <th class="js-sort" data-sort="ip" style="cursor:pointer">IP <span class="sort-ind"></span></th>
        </tr>
      </thead>
      <tbody id="logsTbody"></tbody>
    </table>
    <div id="logsEmpty" style="display:none;padding:40px 20px;text-align:center;color:var(--muted);font-family:var(--font-mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase">
      Записей не найдено
    </div>
  </div>

  <div class="logs-footer">
    <div id="logsStat" class="page-info"></div>
    <div class="pagination" id="logsPagination"></div>
    <div class="logs-pagesize">
      <span class="label" style="margin:0">На странице</span>
      <select id="fPageSize" class="select" style="width:auto">
        <option value="20">20</option>
        <option value="50" selected>50</option>
        <option value="100">100</option>
        <option value="200">200</option>
      </select>
    </div>
  </div>
</section>

<style>
  .logs-filters {
    display: grid;
    grid-template-columns: 2fr 1.2fr 1fr 1fr 1fr auto;
    gap: 12px;
    align-items: end;
  }
  .logs-filter .label { margin-bottom: 4px; }
  .logs-filter-actions { display: flex; align-items: end; }
  .logs-footer {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; margin-top: 12px; flex-wrap: wrap;
  }
  .logs-pagesize { display: flex; gap: 8px; align-items: center; }
  .js-sort .sort-ind { color: var(--muted); margin-left: 4px; font-family: var(--font-mono); font-size: 10px; }
  .js-sort.sort-active .sort-ind { color: var(--primary); }
  .js-sort:hover { color: var(--primary); }
  @media (max-width: 1000px) {
    .logs-filters { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  window.__LOGS_INITIAL__ = {
    logs: <%- JSON.stringify(logs) %>,
    total: <%= total %>,
    params: <%- JSON.stringify(params) %>
  };
</script>
<script src="/js/roles/logs.js"></script>
