<section>
  <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:18px">
    <div>
      <div class="eyebrow" style="margin-bottom:8px">Администрирование · Аудит</div>
      <h1 style="font-size:40px;font-weight:400;letter-spacing:-0.03em;margin:0">
        Журнал <span style="color:var(--primary);font-weight:300">событий</span>
      </h1>
    </div>
    <button class="btn" id="btnExport">⤓ CSV</button>
  </div>

  <div class="card" style="overflow:hidden;margin-bottom:4px">
    <table class="data-table" id="logsTable">
      <thead>
        <tr>
          <th style="width:170px">Дата · Время</th>
          <th style="width:160px">Пользователь</th>
          <th>Действие</th>
          <th style="width:110px">Сущность</th>
          <th style="width:130px">ID</th>
          <th>IP</th>
        </tr>
      </thead>
      <tbody>
      <% logs.forEach(function(l) { %>
        <% var dt = new Date(l.created_at); %>
        <% var dateStr = dt.toLocaleDateString('ru-RU'); %>
        <% var timeStr = dt.toLocaleTimeString('ru-RU'); %>
        <% var isErr = l.action && (l.action.includes('fail') || l.action.includes('err') || l.action.includes('delete')); %>
        <% var isWarn = l.action && (l.action.includes('role') || l.action.includes('deactivate') || l.action.includes('warn')); %>
        <tr>
          <td style="font-family:var(--font-mono);font-size:11px">
            <span style="color:var(--text)"><%= dateStr %></span>
            <span style="color:var(--muted);margin-left:5px"><%= timeStr %></span>
          </td>
          <td>
            <span style="font-size:13px"><%= l.username || '—' %></span>
            <% if (l.role) { %><span class="tag" style="margin-left:6px;font-size:9px"><%= l.role %></span><% } %>
          </td>
          <td>
            <span style="font-family:var(--font-mono);font-size:11px;padding:2px 7px;border-radius:2px;
              background:<%= isErr ? 'var(--danger-soft)' : isWarn ? 'rgba(255,181,71,0.1)' : 'var(--surface-2)' %>;
              color:<%= isErr ? 'var(--danger)' : isWarn ? 'var(--warning)' : 'var(--muted)' %>">
              <%= l.action %>
            </span>
          </td>
          <td style="font-family:var(--font-mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em"><%= l.entity || '—' %></td>
          <td style="font-family:var(--font-mono);font-size:11px;color:var(--ink-2)"><%= l.entity_id || '—' %></td>
          <td style="font-family:var(--font-mono);font-size:11px;color:var(--ink-2)"><%= l.ip || '—' %></td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
  <div style="font-family:var(--font-mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:10px">
    Показано записей: <%= logs.length %>
  </div>
</section>
<script>
$('#btnExport').on('click', function() {
  const rows = [['Дата','Пользователь','Действие','Сущность','ID','IP']];
  $('#logsTable tbody tr').each(function() {
    rows.push($(this).find('td').map((_, td) => '"' + $(td).text().trim().replace(/"/g,'""') + '"').get());
  });
  const csv = '﻿' + rows.map(r => r.join(',')).join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'audit.csv'; a.click();
});
</script>
