<section class="channels-manage">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:24px;gap:24px;flex-wrap:wrap">
    <div>
      <div class="eyebrow" style="margin-bottom:8px">Администрирование · Каналы</div>
      <h1 style="font-size:40px;font-weight:400;letter-spacing:-0.03em;margin:0">
        Каналы <span style="font-family:var(--font-mono);font-size:18px;color:var(--muted);font-weight:400" id="channelCount">· всего <%= activity.total %></span>
      </h1>
    </div>
    <button class="btn btn-primary" id="btnOpenForm">+ Добавить канал</button>
  </div>

  <!-- Stat strip -->
  <div class="channels-stats">
    <div class="channels-stat">
      <div class="channels-stat-n"><%= activity.total %></div>
      <div class="channels-stat-t">всего</div>
    </div>
    <div class="channels-stat">
      <div class="channels-stat-n" style="color:var(--success)"><%= activity.active %></div>
      <div class="channels-stat-t">активных</div>
    </div>
    <div class="channels-stat">
      <div class="channels-stat-n" style="color:var(--muted)"><%= activity.inactive %></div>
      <div class="channels-stat-t">выключенных</div>
    </div>
    <div class="channels-stat channels-stat-accent">
      <div class="channels-stat-n"><%= activity.categories %></div>
      <div class="channels-stat-t">категорий</div>
    </div>
  </div>

  <details id="formBlock" style="margin-bottom:24px"<%= params.openForm ? ' open' : '' %>>
    <summary style="cursor:pointer;font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);list-style:none;padding:14px 18px;background:var(--surface-2);border:1px dashed var(--border);border-radius:var(--radius)">
      <strong id="formTitle" style="color:var(--primary)">+ Добавить канал</strong>
    </summary>
    <form id="channelForm" enctype="multipart/form-data">
      <input type="hidden" name="_id" value="">
      <div class="form-grid">
        <label>Название <span class="req">*</span>
          <input type="text" name="name" required maxlength="128">
        </label>
        <label>Slug (URL-идентификатор)
          <input type="text" name="slug" placeholder="auto из названия" pattern="[a-z0-9-]+">
        </label>
        <label>Категория
          <input type="text" name="category" placeholder="эфирный / спорт / детский" maxlength="64" list="categoryHints">
          <datalist id="categoryHints">
            <% categories.forEach(function(c) { %><option value="<%= c %>"><% }); %>
          </datalist>
        </label>
        <label>Активен
          <select name="isActive">
            <option value="true">Да</option>
            <option value="false">Нет</option>
          </select>
        </label>
        <label class="span-2">Описание
          <textarea name="description" rows="3" maxlength="500"></textarea>
        </label>
        <label>Логотип (PNG/JPEG/WEBP, до 5 МБ)
          <input type="file" name="logo" accept="image/png,image/jpeg,image/webp" id="logoInput">
        </label>
        <div class="logo-preview-block">
          <img id="logoPreview" class="logo-preview" alt="" style="display:none">
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary" id="btnSubmit">Создать</button>
        <button type="button" class="btn" id="btnReset">Сбросить</button>
      </div>
    </form>
  </details>

  <div class="card" style="padding:14px 16px;margin-bottom:14px">
    <div class="channels-filters">
      <div class="channels-filter">
        <span class="label">Поиск</span>
        <input id="fSearch" class="input" type="search" placeholder="Название, slug, описание…" value="<%= params.search || '' %>">
      </div>
      <div class="channels-filter">
        <span class="label">Категория</span>
        <select id="fCategory" class="select">
          <option value="">— все —</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c %>" <%= params.category === c ? 'selected' : '' %>><%= c %></option>
          <% }); %>
        </select>
      </div>
      <div class="channels-filter">
        <span class="label">Статус</span>
        <select id="fStatus" class="select">
          <option value="">— все —</option>
          <option value="true"  <%= params.isActive === true  ? 'selected' : '' %>>Активные</option>
          <option value="false" <%= params.isActive === false ? 'selected' : '' %>>Выключенные</option>
        </select>
      </div>
      <div class="channels-filter channels-filter-actions">
        <button class="btn btn-sm" id="fReset" type="button">Сбросить</button>
      </div>
    </div>
  </div>

  <div class="card" style="overflow:hidden">
    <table class="data-table" id="channelsTable">
      <thead>
        <tr>
          <th style="width:60px">Лого</th>
          <th class="js-sort" data-sort="id" style="width:60px;cursor:pointer">№ <span class="sort-ind"></span></th>
          <th class="js-sort" data-sort="name" style="cursor:pointer">Название <span class="sort-ind"></span></th>
          <th class="js-sort" data-sort="slug" style="width:140px;cursor:pointer">Slug <span class="sort-ind"></span></th>
          <th class="js-sort" data-sort="category" style="width:170px;cursor:pointer">Категория <span class="sort-ind"></span></th>
          <th class="js-sort" data-sort="is_active" style="width:110px;cursor:pointer">Активен <span class="sort-ind"></span></th>
          <th>Описание</th>
          <th style="width:90px"></th>
        </tr>
      </thead>
      <tbody id="channelsTbody"></tbody>
    </table>
    <div id="channelsEmpty" style="display:none;padding:40px 20px;text-align:center;color:var(--muted);font-family:var(--font-mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase">
      Каналов не найдено
    </div>
  </div>

  <div class="channels-footer">
    <div id="channelsStat" class="page-info"></div>
    <div class="pagination" id="channelsPagination"></div>
    <div class="channels-pagesize">
      <span class="label" style="margin:0">На странице</span>
      <select id="fPageSize" class="select" style="width:auto">
        <option value="10">10</option>
        <option value="20" selected>20</option>
        <option value="50">50</option>
        <option value="100">100</option>
      </select>
    </div>
  </div>
</section>

<style>
  .channels-manage .channels-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--border);
    margin-bottom: 24px;
    background: var(--surface);
  }
  .channels-stat {
    padding: 18px 22px;
    border-right: 1px solid var(--border);
  }
  .channels-stat:last-child { border-right: none; }
  .channels-stat-accent {
    background: var(--accent-soft);
    border-top: 1px solid var(--primary);
    margin-top: -1px;
  }
  .channels-stat-accent .channels-stat-n { color: var(--primary); }
  .channels-stat-accent .channels-stat-t { color: var(--primary-dark); }
  .channels-stat-n {
    font-family: var(--font-sans);
    font-weight: 300; font-size: 38px; line-height: 1;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .channels-stat-t {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--muted);
    margin-top: 8px;
  }
  .channels-filters {
    display: grid;
    grid-template-columns: 2fr 1.2fr 1.2fr auto;
    gap: 12px;
    align-items: end;
  }
  .channels-filter .label { margin-bottom: 4px; }
  .channels-filter-actions { display: flex; align-items: end; }
  .channels-footer {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; margin-top: 12px; flex-wrap: wrap;
  }
  .channels-pagesize { display: flex; gap: 8px; align-items: center; }
  .js-sort .sort-ind { color: var(--muted); margin-left: 4px; font-family: var(--font-mono); font-size: 10px; }
  .js-sort.sort-active .sort-ind { color: var(--primary); }
  .js-sort:hover { color: var(--primary); }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; padding: 20px; background: var(--surface-2); border: 1px solid var(--border); border-top: none; border-radius: 0 0 var(--radius) var(--radius); }
  .form-grid .span-2 { grid-column: span 2; }
  .form-grid label { margin: 0; font-family: var(--font-mono); font-size: 9px; text-transform: uppercase; letter-spacing: .16em; color: var(--muted); display: flex; flex-direction: column; gap: 6px; }
  .form-grid label::before { content: "// "; color: var(--primary); opacity: .6; }
  .form-grid input, .form-grid select, .form-grid textarea { margin: 0; }
  .form-actions { padding: 14px 20px; background: var(--surface-2); border: 1px solid var(--border); border-top: 1px solid var(--border-soft); display: flex; gap: 8px; }
  .logo-preview { max-width: 100px; max-height: 100px; border-radius: var(--radius); border: 1px solid var(--border); }
  .thumb { width: 40px; height: 40px; object-fit: cover; border-radius: var(--radius); border: 1px solid var(--border); }
  .thumb-placeholder { width: 40px; height: 40px; background: var(--surface-3); border: 1px solid var(--border); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-weight: 600; color: var(--primary); }
  .desc-cell { max-width: 280px; color: var(--muted); font-size: 12px; }
  .actions-cell { white-space: nowrap; text-align: right; }
  .req { color: var(--danger); }
  .channel-active-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .08em;
  }
  code { background: var(--surface-2); border: 1px solid var(--border); padding: 1px 6px; border-radius: 2px; font-size: 11px; font-family: var(--font-mono); color: var(--ink-2); }
  @media (max-width: 900px) {
    .channels-manage .channels-stats { grid-template-columns: repeat(2, 1fr); }
    .channels-manage .channels-stats .channels-stat:nth-child(2) { border-right: none; }
    .channels-filters { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 700px) {
    .form-grid { grid-template-columns: 1fr; }
    .form-grid .span-2 { grid-column: span 1; }
  }
  #formBlock summary::-webkit-details-marker { display: none; }
</style>

<script>
  window.__CHANNELS_INITIAL__ = {
    channels: <%- JSON.stringify(channels) %>,
    total: <%= total %>,
    params: <%- JSON.stringify(params) %>,
    activity: <%- JSON.stringify(activity) %>
  };
</script>
<script src="/js/roles/admin-channels.js"></script>
