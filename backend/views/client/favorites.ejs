<section class="favorites-page">
  <div class="eyebrow" style="margin-bottom:8px">Закладки</div>
  <h1 style="font-size:48px;font-weight:400;letter-spacing:-0.03em;margin:0 0 32px">
    В <span style="color:var(--primary);font-weight:300">избранном</span>
  </h1>

  <% if (favChannels.length === 0 && favPrograms.length === 0) { %>
    <div style="text-align:center;padding:48px 24px;border:1px solid var(--border);border-radius:var(--radius);color:var(--muted)">
      <div style="font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:.2em;margin-bottom:16px">— Пусто —</div>
      <p style="margin:0 0 20px;font-size:14px">У вас пока нет ничего в избранном.</p>
      <div style="display:flex;gap:8px;justify-content:center">
        <a href="/" class="btn">К расписанию</a>
      </div>
    </div>
  <% } %>

  <% if (favChannels.length > 0) { %>
    <div style="display:flex;align-items:end;justify-content:space-between;margin-bottom:14px">
      <div>
        <h2 style="font-size:22px;font-weight:500;margin:0">Любимые каналы</h2>
        <div style="font-family:var(--font-mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:5px"><%= favChannels.length %> канала</div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;margin-bottom:40px">
      <% favChannels.forEach(function(channel) { %>
        <div class="card" style="padding:20px;display:grid;grid-template-columns:48px 1fr;gap:14px;align-items:center">
          <div style="font-family:var(--font-mono);font-weight:300;font-size:32px;color:var(--muted);line-height:1;text-align:right"><%= String(channel.id).padStart(2,'0') %></div>
          <div>
            <div style="font-size:18px;font-weight:500;line-height:1"><%= channel.name %></div>
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:6px"><%= channel.category || 'Канал' %></div>
            <div style="display:flex;gap:6px;margin-top:12px">
              <a href="/" class="btn btn-sm">Расписание</a>
              <button class="btn btn-sm btn-danger js-fav-remove" data-type="channel" data-id="<%= channel.id %>">★ Убрать</button>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>

  <% if (favPrograms.length > 0) { %>
    <div style="display:flex;align-items:end;justify-content:space-between;margin-bottom:14px">
      <div>
        <h2 style="font-size:22px;font-weight:500;margin:0">Любимые передачи</h2>
        <div style="font-family:var(--font-mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:5px"><%= favPrograms.length %> передач</div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px">
      <% favPrograms.forEach(function(program) { %>
        <div class="card" style="padding:14px;display:flex;flex-direction:column;gap:10px">
          <%- include('../partials/program-card', { program }) %>
          <div style="display:flex;justify-content:flex-end;margin-top:auto">
            <button class="btn btn-sm btn-danger js-fav-remove" data-type="program" data-id="<%= program.id %>">★ Убрать</button>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</section>

<script>
$(function() {
  $('.js-fav-remove').on('click', function() {
    const $btn = $(this);
    const type = $btn.data('type'), id = $btn.data('id');
    if (!confirm('Убрать из избранного?')) return;
    $.ajax({ url: `/client/api/favorites/${type}/${id}`, method: 'DELETE' })
      .done(() => location.reload())
      .fail((xhr) => alert('Ошибка: ' + (xhr.responseJSON?.message || xhr.statusText)));
  });
});
</script>
