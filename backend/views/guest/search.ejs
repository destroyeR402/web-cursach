<%
function pluralize(n, one, few, many) {
  const mod10 = n % 10, mod100 = n % 100;
  if (mod10 === 1 && mod100 !== 11) return one;
  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 10 || mod100 >= 20)) return few;
  return many;
}
%>
<section class="search-page">
  <h1>Поиск передач</h1>
  <p class="muted">Используйте любую комбинацию фильтров (название, жанр, дата) или один из них — они работают независимо.</p>

  <form method="GET" action="/search" class="search-form">
    <label class="span-3">
      <span>Название передачи</span>
      <input type="search" name="q" value="<%= q %>" placeholder="например, «новости» или «футбол»">
    </label>
    <label>
      <span>Жанр</span>
      <select name="genreId">
        <option value="">— любой —</option>
        <% genres.forEach(function(g) { %>
          <option value="<%= g.id %>" <%= genreId == g.id ? 'selected' : '' %>><%= g.name %></option>
        <% }); %>
      </select>
    </label>
    <label>
      <span>Дата эфира</span>
      <input type="date" name="date" value="<%= date %>">
    </label>
    <div class="form-buttons">
      <button class="btn btn-primary" type="submit">🔍 Найти</button>
      <a class="btn" href="/search">Сбросить</a>
    </div>
  </form>

  <% if (!hasFilter) { %>
    <div class="empty-state">
      <p class="muted">Введите название, выберите жанр или дату — и нажмите «Найти».</p>
      <p class="muted small">Подсказка: для поиска всех мультфильмов — выберите жанр «Мультфильмы» и нажмите «Найти», без указания названия и даты.</p>
    </div>
  <% } else { %>
    <div class="results-header">
      <h2>
        <% if (results.mode === 'slots') { %>
          В эфире <%= date %>: найдено <%= results.count %> <%= pluralize(results.count, 'передача','передачи','передач') %>
        <% } else { %>
          В справочнике: найдено <%= results.count %> <%= pluralize(results.count, 'передача','передачи','передач') %>
        <% } %>
      </h2>
      <div class="filter-summary">
        <% if (q)       { %><span class="tag">название: «<%= q %>»</span><% } %>
        <% if (genreId) { %><span class="tag">жанр: <%= (genres.find(g => g.id == genreId) || {}).name %></span><% } %>
        <% if (date)    { %><span class="tag">дата: <%= date %></span><% } %>
      </div>
    </div>

    <% if (results.count === 0) { %>
      <div class="empty-state">
        <p class="muted">Ничего не найдено по выбранным фильтрам.</p>
      </div>
    <% } else if (results.mode === 'slots') { %>
      <%# === Результаты с датой — список слотов === %>
      <table class="data-table slots-table">
        <thead>
          <tr><th>Время</th><th>Канал</th><th>Передача</th><th>Жанр</th><th>Возраст</th><th>Длительность</th></tr>
        </thead>
        <tbody>
          <% results.items.forEach(function(s) { %>
            <% const start = new Date(s.starts_at); %>
            <% const end = new Date(s.ends_at); %>
            <tr>
              <td class="time-cell">
                <%= String(start.getHours()).padStart(2,'0') %>:<%= String(start.getMinutes()).padStart(2,'0') %>
                –
                <%= String(end.getHours()).padStart(2,'0') %>:<%= String(end.getMinutes()).padStart(2,'0') %>
              </td>
              <td>
                <% if (s.channel_logo) { %><img src="<%= s.channel_logo %>" class="thumb-mini"><% } %>
                <%= s.channel_name %>
              </td>
              <td><strong><%= s.title %></strong></td>
              <td><% if (s.genre_name) { %><span class="tag"><%= s.genre_name %></span><% } %></td>
              <td><% if (s.age_code) { %><span class="tag age"><%= s.age_code %></span><% } %></td>
              <td><%= s.duration_min %> мин</td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <%# === Без даты — карточки передач === %>
      <div class="cards-grid">
        <% results.items.forEach(function(program) { %>
          <article class="program-card">
            <% if (program.poster_path) { %>
              <img class="program-poster" src="<%= program.poster_path %>" alt="<%= program.title %>">
            <% } else { %>
              <div class="program-poster poster-placeholder"><%= program.title.charAt(0) %></div>
            <% } %>
            <div class="program-info">
              <h4><%= program.title %></h4>
              <div class="program-meta">
                <% if (program.genre_name) { %><span class="tag"><%= program.genre_name %></span><% } %>
                <% if (program.age_code) { %><span class="tag age"><%= program.age_code %></span><% } %>
                <% if (program.duration_min) { %><span class="muted"><%= program.duration_min %> мин</span><% } %>
              </div>
              <% if (program.description) { %>
                <p class="muted desc-clip"><%= program.description %></p>
              <% } %>
              <% if (program.channels && program.channels.length > 0) { %>
                <div class="program-channels">
                  <small class="muted">Показывают на:</small>
                  <% program.channels.forEach(function(c) { %>
                    <a href="/?date=<%= new Date().toLocaleDateString('sv-SE') %>" class="channel-chip" title="<%= c.name %>">
                      <% if (c.logo_path) { %><img src="<%= c.logo_path %>" alt=""><% } %>
                      <span><%= c.name %></span>
                    </a>
                  <% }); %>
                </div>
              <% } %>
              <div class="program-extra">
                <% if (program.next_show_at) { %>
                  <small class="next-show">📅 Ближайший эфир: <%= new Date(program.next_show_at).toLocaleString('ru-RU',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %></small>
                <% } else if (program.recent_slot_count > 0) { %>
                  <small class="muted">Транслировалась <%= program.recent_slot_count %> раз за 2 недели</small>
                <% } else { %>
                  <small class="muted">Нет ближайших показов</small>
                <% } %>
              </div>
              <% if (user) { %>
                <button class="btn btn-sm btn-fav-card" data-type="program" data-id="<%= program.id %>" title="В избранное">
                  ♡ В избранное
                </button>
              <% } %>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>
  <% } %>
</section>

<style>
  .search-form { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 12px; align-items: end; margin-bottom: 24px; padding: 16px; background: var(--surface); border-radius: var(--radius); }
  .search-form label { margin: 0; }
  .search-form .span-3 { grid-column: span 3; }
  .form-buttons { grid-column: span 3; display: flex; gap: 8px; }
  .results-header { margin-top: 24px; padding: 12px 16px; background: var(--surface); border-radius: var(--radius); }
  .results-header h2 { margin: 0; font-size: 1.1rem; }
  .filter-summary { margin-top: 8px; display: flex; gap: 6px; flex-wrap: wrap; }
  .empty-state { text-align: center; padding: 40px 16px; background: var(--surface); border-radius: var(--radius); margin-top: 16px; }
  .small { font-size: 0.85rem; }
  .time-cell { font-variant-numeric: tabular-nums; white-space: nowrap; color: var(--primary); }
  .thumb-mini { width: 24px; height: 24px; object-fit: cover; border-radius: 4px; vertical-align: middle; margin-right: 4px; }
  .desc-clip { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .next-show { color: var(--primary); }
  .program-extra { margin-top: 8px; }
  .poster-placeholder { display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 700; color: var(--muted); background: var(--surface-2); }
  .program-channels { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 4px; align-items: center; }
  .program-channels small { width: 100%; margin-bottom: 4px; }
  .channel-chip { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px; background: var(--surface-2); border-radius: 12px; font-size: 0.8rem; color: var(--text); border: 1px solid var(--border); }
  .channel-chip img { width: 18px; height: 18px; object-fit: cover; border-radius: 50%; }
  .channel-chip:hover { background: var(--primary); border-color: var(--primary); text-decoration: none; color: #fff; }
  .btn-fav-card { margin-top: 8px; display: block; width: 100%; }
  .btn-fav-card.is-fav { background: var(--danger); border-color: var(--danger); color: #fff; }
  @media (max-width: 700px) {
    .search-form { grid-template-columns: 1fr; }
    .search-form .span-3, .form-buttons { grid-column: span 1; }
  }
</style>
